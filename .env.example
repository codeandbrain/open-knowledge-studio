# Open Knowledge Studio v2 — Environment Configuration
# Copy this file to .env and fill in your values.

# ─── Google Gemini API Key (Required for AI chat) ───
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# ─── Google OAuth Client ID (Optional, for Google Workspace features) ───
# Get from: https://console.cloud.google.com/apis/credentials
# Create OAuth 2.0 Client ID → Web Application
# Add authorized origins: http://localhost:3000
VITE_GOOGLE_OAUTH_CLIENT_ID=

# ─── Notes ───
# - Only the Google Client ID goes in browser code (public).
# - Never put a Google Client Secret in this file — it's visible in the browser bundle.
# - API keys for OpenAI/Anthropic/DeepSeek/Groq are entered in the Settings UI at runtime.
# - Ollama runs locally and needs no API key.
